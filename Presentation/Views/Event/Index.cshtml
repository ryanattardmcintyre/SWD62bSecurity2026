@model IEnumerable<Common.Models.Event>
@{
    ViewData["Title"] = "Events";
}

<div class="container mt-4">
    <h1>@ViewData["Title"]</h1>

    @if (TempData["success"] != null)
    {
        <div class="alert alert-success" role="alert">@TempData["success"]</div>
    }

    <p>
        <a asp-controller="Event" asp-action="Create" class="btn btn-primary">Create New Event</a>
    </p>

    <table class="table table-bordered table-striped">
        <thead class="table-light">
            <tr>
                <th>Name</th>
                <th>Price</th>
                <th>Maximum Tickets</th>
                <th>Image</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @if (Model == null || !Model.Any())
            {
                <tr>
                    <td colspan="8" class="text-center text-muted">No events found.</td>
                </tr>
            }
            else
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@string.Format("{0:C}", item.Price)</td>
                        
                        <td>@item.MaximumTickets</td>
                        <td style="width:120px;">
                            @if (!string.IsNullOrEmpty(item.FilePath))
                            {
                                <img src="@item.FilePath" alt="@item.Name" style="max-width:100px; max-height:80px;" />
                            }
                            else
                            {
                                <span class="text-muted">No image</span>
                            }
                        </td>
                        <td>
                            <a href="/tickets/buy/@item.Id" class="btn btn-warning">Buy</a>

                            @{
                              var myParams=  Presentation.Helpers.SymmetricEncryptionHelper.GenerateSymmetricParameters(
                            System.Security.Cryptography.Aes.Create(),
                            "p@$$w0rd"
                            );
                                var encryptedId = Presentation.Helpers.SymmetricEncryptionHelper.Encrypt(item.Id.ToString(),
                                 myParams,System.Security.Cryptography.Aes.Create() );
                            }

                            <a href="/event/details?id=@encryptedId" class="btn btn-info">View Details</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
